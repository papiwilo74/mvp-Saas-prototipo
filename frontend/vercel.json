{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https:; form-action 'self'; upgrade-insecure-requests"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/sw.js", "destination": "/sw.js" },
    { "source": "/manifest.json", "destination": "/manifest.json" },
    { "source": "/icons/:path*", "destination": "/icons/:path*" },
    { "source": "/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/(.*)", "destination": "/" }
  ],
  "redirects": [
    { "source": "/.env", "destination": "/", "permanent": false },
    { "source": "/.env.local", "destination": "/", "permanent": false },
    { "source": "/.git/:path*", "destination": "/", "permanent": false },
    { "source": "/backup", "destination": "/", "permanent": false },
    { "source": "/backup.zip", "destination": "/", "permanent": false },
    { "source": "/old", "destination": "/", "permanent": false },
    { "source": "/debug", "destination": "/", "permanent": false },
    { "source": "/test", "destination": "/", "permanent": false },
    { "source": "/config", "destination": "/", "permanent": false },
    { "source": "/config.php", "destination": "/", "permanent": false },
    { "source": "/db.sql", "destination": "/", "permanent": false },
    { "source": "/database.sql", "destination": "/", "permanent": false },
    { "source": "/docker-compose.yml", "destination": "/", "permanent": false },
    { "source": "/package.json", "destination": "/", "permanent": false },
    { "source": "/requirements.txt", "destination": "/", "permanent": false },
    { "source": "/phpmyadmin", "destination": "/", "permanent": false },
    { "source": "/wp-admin", "destination": "/", "permanent": false },
    { "source": "/api/v1", "destination": "/", "permanent": false }
  ]
}