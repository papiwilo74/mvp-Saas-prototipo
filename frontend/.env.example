# ============================================================
# FRONTEND environment variables
# Copy this file to .env:
#   cp .env.example .env
# ============================================================

# --- API ---
# URL of the backend API. In development this points to localhost.
# In production, set this to your deployed backend URL.
VITE_API_URL="http://localhost:4000/api"

# --- Restaurant ---
# Default restaurant slug. The app also detects the slug from the URL
# path or from the ?restaurant= query parameter.
VITE_RESTAURANT_SLUG="demo-burger"

# --- Features ---
# Set to "false" to disable the order history page.
VITE_ENABLE_ORDER_HISTORY="true"

# --- Demo mode ---
# When true, shows a demo banner and uses demo restaurant data.
# Automatically enabled when the restaurant slug contains "demo".
VITE_DEMO_MODE="true"
