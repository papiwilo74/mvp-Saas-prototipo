# ============================================================
# FRONTEND production environment template
# Copy this to .env on your hosting platform (Vercel, Netlify, etc.)
# or use the platform's own env-var dashboard.
# ============================================================

# --- API ---
# Points to your deployed backend (Railway, Render, etc.).
# Must be the full URL including /api.
VITE_API_URL="https://tu-backend.up.railway.app/api"

# --- Restaurant ---
# Default restaurant slug for your production tenant.
VITE_RESTAURANT_SLUG="demo-burger"

# --- Features ---
VITE_ENABLE_ORDER_HISTORY="true"

# --- Demo mode ---
# Should be "false" for a real restaurant deployment.
VITE_DEMO_MODE="false"
