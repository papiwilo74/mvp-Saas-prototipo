# ============================================================
# Backend Environment Variables
#
# SETUP:
#   1. Copy this file to .env:
#        cp .env.example .env
#   2. Fill in real values for your environment.
#   3. Run "npm run env:validate" to check your config.
#   4. Run "npm run bootstrap" to install deps and init the DB.
#
# For development, see: .env.development
# For production, see:  .env.production.example
# ============================================================

# ============================
# App
# ============================
NODE_ENV=development
PORT=4000

# ============================
# Database (PostgreSQL / Supabase)
# ============================
# Connection string for Prisma. Use the pooler URL in production.
DATABASE_URL="postgresql://postgres:password@localhost:5432/fastfood_saas?schema=public"
# Direct connection for migrations (only needed with Supabase pooler).
DIRECT_URL="postgresql://postgres:password@localhost:5432/fastfood_saas?schema=public"

# ============================
# Auth (JWT)
# ============================
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-with-a-long-secret-at-least-24-chars"
JWT_EXPIRES_IN="7d"

# ============================
# Frontend (CORS)
# ============================
# URL of the frontend app. Used for CORS and redirects.
FRONTEND_URL="http://localhost:5173"
# Comma-separated list of allowed CORS origins.
ALLOWED_ORIGINS="http://localhost:5173"

# ============================
# Rate Limiting
# ============================
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10
PUBLIC_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_RATE_LIMIT_MAX=60

# ============================
# Email (Resend — optional)
# ============================
# Get your API key at https://resend.com
RESEND_API_KEY="re_xxxxxxxxx"
EMAIL_FROM="FastFood SaaS <pedidos@tu-dominio.com>"

# ============================
# Cloudinary (image uploads — optional)
# ============================
# Get credentials at https://cloudinary.com
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="123456789"
CLOUDINARY_API_SECRET="abc123def456"
