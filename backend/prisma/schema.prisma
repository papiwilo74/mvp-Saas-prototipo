generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPERADMIN
}

enum OrderStatus {
  PENDING
  PREPARING
  ON_THE_WAY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  NEQUI
  CARD
  WOMPI
}

enum PaymentStatus {
  PENDING
  APPROVED
  DECLINED
  ERROR
}

enum LoyaltyTier {
  BRONCE
  PLATA
  ORO
  DIAMANTE
}

model Restaurant {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  email     String?
  phone     String?
  address   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  users     User[]
  config    RestaurantConfig?
  categories Category[]
  products  Product[]
  orders    Order[]
  customers Customer[]
}

model RestaurantConfig {
  id             String     @id @default(cuid())
  restaurantName String
  logoUrl        String?
  heroImageUrl   String?
  primaryColor   String     @default("#ea580c")
  secondaryColor String     @default("#141414")
  phone          String?
  whatsapp       String?
  address        String?
  email          String?
  facebookUrl    String?
  instagramUrl   String?
  openingHours   String?
  businessHours  Json?
  acceptsScheduledOrders Boolean @default(false)
  leadTimeMinutes Int      @default(30)
  deliveryFee    Decimal?   @db.Decimal(10, 2)
  deliveryZones  Json?
  coupons        Json?
  paymentMethods String[]   @default([])
  wompiPublicKey String?
  wompiPrivateKey String?
  loyaltyProgram Json?
  restaurantId   String     @unique
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(CUSTOMER)
  restaurantId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  orders       Order[]
}

model Category {
  id           String     @id @default(cuid())
  name         String
  description  String?
  sortOrder    Int        @default(0)
  restaurantId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  sortOrder Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Product {
  id           String         @id @default(cuid())
  name         String
  description  String
  price        Decimal        @db.Decimal(10, 2)
  imageUrl     String?
  isAvailable  Boolean        @default(true)
  trackStock   Boolean        @default(false)
  stock        Int?
  isCombo      Boolean        @default(false)
  comboItems   String[]       @default([])
  variants     Json?
  isDeleted    Boolean        @default(false)
  restaurantId String
  categoryId   String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category     Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems   OrderItem[]
  images       ProductImage[]

  @@index([restaurantId])
  @@index([categoryId])
  @@unique([restaurantId, name])
}

model Customer {
  id           String        @id @default(cuid())
  name         String
  phone        String?
  email        String?
  address      String?
  notes        String?
  points       Int           @default(0)
  tier         LoyaltyTier   @default(BRONCE)
  restaurantId String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders       Order[]
  transactions PaymentTransaction[]

  @@unique([restaurantId, phone])
  @@index([restaurantId])
  @@index([restaurantId, email])
}

model Order {
  id           String      @id @default(cuid())
  orderNumber  Int         @unique @default(autoincrement())
  status       OrderStatus @default(PENDING)
  paymentMethod PaymentMethod @default(CASH)
  paymentStatus PaymentStatus @default(PENDING)
  subtotal     Decimal     @default(0) @db.Decimal(10, 2)
  deliveryFeeApplied Decimal @default(0) @db.Decimal(10, 2)
  discountAmount Decimal   @default(0) @db.Decimal(10, 2)
  pointsRedeemed Int       @default(0)
  total        Decimal     @db.Decimal(10, 2)
  couponCode   String?
  notes        String?
  customerName String
  customerPhone String?
  customerEmail String?
  customerAddress String?
  deliveryZoneName String?
  scheduledFor DateTime?
  wompiTransactionId String?
  restaurantId String
  userId       String?
  customerId   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  customer     Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items        OrderItem[]

  @@index([restaurantId])
  @@index([userId])
  @@index([customerId])
  @@index([scheduledFor])
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)
  orderId   String
  productId String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model PaymentTransaction {
  id            String        @id @default(cuid())
  wompiId       String        @unique
  status        PaymentStatus @default(PENDING)
  amountInCents Int
  currency      String        @default("COP")
  reference     String
  customerId    String?
  customer      Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}
