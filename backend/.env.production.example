# ============================================================
# PRODUCTION environment template
# DO NOT use this file directly. Copy it to .env on your
# production server and fill in real values for every field.
# ============================================================

# --- App ---
NODE_ENV=production
PORT=4000

# --- Database (Supabase / hosted PostgreSQL) ---
# Use the Transaction pooler URL for DATABASE_URL (port 6543).
# DIRECT_URL is required for Prisma migrations (uses session mode, port 5432).
# Replace TU_PASSWORD, TU_REF with your actual Supabase credentials.
DATABASE_URL="postgresql://postgres:TU_PASSWORD@TU_POOLER_HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:TU_PASSWORD@db.TU_REF.supabase.co:5432/postgres?sslmode=require"

# --- Auth (JWT) ---
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE-WITH-A-STRONG-RANDOM-64-BYTE-HEX-STRING"
JWT_EXPIRES_IN="7d"

# --- Frontend ---
# Must be the URL of your deployed frontend (Vercel, Netlify, etc.).
# Do NOT use localhost here.
FRONTEND_URL="https://tu-frontend.vercel.app"
ALLOWED_ORIGINS="https://tu-frontend.vercel.app"

# --- Rate Limiting ---
# Tighter limits for production to prevent abuse.
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=5
PUBLIC_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_RATE_LIMIT_MAX=60

# --- Email (Resend) ---
# Sign up at https://resend.com, verify your domain, and get an API key.
RESEND_API_KEY="re_xxxxxxxxx"
EMAIL_FROM="FastFood SaaS <pedidos@tu-dominio.com>"

# --- Cloudinary (image uploads) ---
# Sign up at https://cloudinary.com and get credentials from the dashboard.
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="123456789"
CLOUDINARY_API_SECRET="abc123def456"
